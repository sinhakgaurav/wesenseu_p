# Application
APP_NAME=Monitour
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://monitour:password@localhost:5432/monitour_db
SYNC_DATABASE_URL=postgresql://monitour:password@localhost:5432/monitour_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AWS S3 / Object Storage
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET_NAME=monitour-media
AWS_REGION=ap-south-1
S3_ENDPOINT_URL=

# WesenseU AI Verification
WESENSEU_API_URL=https://api.wesenseu.com/v1
WESENSEU_API_KEY=your-wesenseu-api-key

# Firebase Push Notifications
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@monitour.in
SMTP_PASSWORD=your-smtp-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
